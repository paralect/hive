{
	"compilerOptions": {
		"moduleDetection": "force",
		"module": "Preserve",
		"resolveJsonModule": true,
		"allowJs": true,
		"esModuleInterop": true,
		"isolatedModules": true,
		"noEmit": true,
		"baseUrl": ".",
		"paths": {
			"@hive": [".hive/src/index"],
			"@hive/*": [".hive/src/*"],
			"@/*": ["hive/*"]
		}
	},
	"include": [
		"hive/**/*",
		".hive/src/**/*"
	]
}
{
  "name": "{{PROJECT_NAME}}",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "turbo run dev dev:api",
    "dev:api": "hive prepare ./apps/api && HIVE_SRC=$PWD/apps/api npm -C .hive run dev",
    "prepare": "hive prepare ./apps/api",
    "start": "hive prepare ./apps/api && HIVE_SRC=$PWD/apps/api npm -C .hive run start",
    "build": "turbo run build"
  },
  "dependencies": {
    "@koa/multer": "^4.0.0",
    "@paralect/hive": "{{HIVE_DEP}}",
    "lodash": "^4.17.23",
    "moment": "^2.30.1"
  },
  "devDependencies": {
    "turbo": "^2"
  }
}